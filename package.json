{
  "name": "concurso-loqueleo",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "build:frontend": "npm run build --prefix frontend",
    "build:backend": "npm run build --prefix backend",
    "docker:db": "docker compose up db -d",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build",
    "docker:dev:detach": "docker compose -f docker-compose.dev.yml up --build -d",
    "docker:up": "docker compose up --build",
    "docker:up:s3": "docker compose -f docker-compose.yml -f docker-compose.s3-local.yml up --build",
    "docker:down": "docker compose down",
    "docker:stop-app": "docker compose stop frontend backend",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}

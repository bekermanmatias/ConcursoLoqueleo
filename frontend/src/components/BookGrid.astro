---
import AgeFilter from "./AgeFilter.tsx";
import BookCard from "./BookCard.astro";
import { books } from "../data/books";
---

<section id="retos" class="relative z-30 -mt-44 sm:-mt-52 lg:-mt-60 pb-14 sm:pb-20">
  <header class="mb-8 sm:mb-10">
    <h2 class="section-title">
      Explora los retos
    </h2>
    <p class="mt-3 text-sm sm:text-base text-[color:var(--color-ink-700)] max-w-2xl leading-relaxed">
      Cada grado tiene una obra y un reto. Busca el tuyo por el nombre del grado en la tarjeta
      (de 1.° primaria a 5.° secundaria).
    </p>
  </header>

  <AgeFilter client:load />

  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-5 mt-10 sm:mt-12 items-stretch">
    {books.map((book) => (
      <BookCard book={book} />
    ))}
  </div>
</section>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import BookGrid from "../components/BookGrid.tsx";
import Prizes from "../components/Prizes.astro";
import Ayuda from "../components/Ayuda.astro";
import { fetchPublicObrasServer } from "../lib/concurso-server";

const initialBooks = await fetchPublicObrasServer();
---

<BaseLayout>
  <Hero />
  <section class="relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <BookGrid client:load initialBooks={initialBooks} />
      <Prizes />
      <Ayuda />
    </div>
  </section>
</BaseLayout>

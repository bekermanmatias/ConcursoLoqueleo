---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import RegistrationWizard from "../../../components/flow/RegistrationWizard.tsx";
import { ageUiStyles } from "../../../data/books";
import {
  fetchPublicObraServer,
  fetchPublicObraSlugsServer,
  fetchPublicConcursoServer,
} from "../../../lib/concurso-server";
import { resolveTermsPdfUrl } from "../../../lib/legal";
import { inscripcionesEstanAbiertas } from "../../../lib/inscripciones";
import InscripcionesCerradas from "../../../components/flow/InscripcionesCerradas.tsx";

export async function getStaticPaths() {
  const slugs = await fetchPublicObraSlugsServer();
  return slugs.map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
const book = await fetchPublicObraServer(id!);

if (!book) {
  return Astro.redirect("/");
}

const { accent } = ageUiStyles[book.age];
const activeConcurso = await fetchPublicConcursoServer();
const termsPdfUrl = resolveTermsPdfUrl(activeConcurso?.terminosPdf);
const inscripcionesAbiertas = inscripcionesEstanAbiertas(activeConcurso);
---

<BaseLayout
  title={`Participar — ${book.title}`}
  description="Registro y subida de tu trabajo para Soy Loqueleo 2026."
>
  <div class="book-detail-page book-detail-page--participar">
    <div class="book-detail-inner relative z-10">
      <div class="participar-form">
        {inscripcionesAbiertas ? (
          <RegistrationWizard
            client:load
            bookId={book.id}
            bookTitle={book.title}
            bookGrade={book.grade}
            bookFormats={book.formats}
            accent={accent}
            termsPdfUrl={termsPdfUrl}
          />
        ) : (
          <InscripcionesCerradas client:load bookId={book.id} bookTitle={book.title} />
        )}
      </div>
    </div>

    <img
      src="/estrellas izquierda.png"
      alt=""
      class="book-detail-stars-left"
      width={340}
      height={340}
      loading="eager"
      decoding="async"
      aria-hidden="true"
    />
    <img
      src="/luna.png"
      alt=""
      class="book-detail-moon"
      width={340}
      height={340}
      loading="eager"
      decoding="async"
      aria-hidden="true"
    />
  </div>
</BaseLayout>

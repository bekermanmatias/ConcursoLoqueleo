---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatGradeLabel } from "../../lib/books";
import { ageUiStyles } from "../../data/books";
import {
  fetchPublicObraServer,
  fetchPublicObraSlugsServer,
} from "../../lib/concurso-server";

export async function getStaticPaths() {
  const slugs = await fetchPublicObraSlugsServer();
  return slugs.map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
const book = await fetchPublicObraServer(id!);

if (!book) {
  return Astro.redirect("/");
}

const { accent } = ageUiStyles[book.age];
const participarUrl = `/libro/${book.id}/participar/`;
const gradeLabel = formatGradeLabel(book.grade);
---

<BaseLayout
  title={`${book.title} — Soy Loqueleo 2026`}
  description={book.challenge}
>
  <div class="book-detail-page py-4 sm:py-6 pb-12 sm:pb-16 lg:pb-20">
    <div class="book-detail-inner relative z-10">
      <div class="grid lg:grid-cols-[minmax(240px,340px)_1fr] gap-6 lg:gap-8 items-start">
      <div class="mx-auto lg:mx-0 w-full max-w-[340px]">
        <div
          class="rounded-2xl border-2 overflow-hidden shadow-lg bg-white"
          style={`border-color: ${accent};`}
        >
          <img
            src={book.cover}
            alt={`Tapa de ${book.title}`}
            width={340}
            height={454}
            class="w-full h-auto block"
          />
        </div>
      </div>

      <div class="min-w-0">
        <p class="book-detail-grade" style={`color: ${accent};`}>{gradeLabel}</p>
        <h1 class="mt-1 text-2xl sm:text-3xl lg:text-4xl font-extrabold text-ink-900 leading-tight">
          {book.title}
        </h1>
        <p class="mt-2 text-gray-500">{book.author}</p>

        {!book.deliverable && (
          <div class="book-card-role justify-start mt-4">
            <span
              class="book-card-badge"
              style={`background: ${accent};`}
            >
              {book.age}
            </span>
            <p
              class="book-card-role-label text-base sm:text-lg"
              style={`color: ${accent};`}
            >
              {book.role}
            </p>
          </div>
        )}

        {book.deliverable ? (
          <section class="challenge-simple mt-3" style={`--challenge-accent: ${accent};`}>
            <div class="challenge-simple-role-row book-card-role justify-start">
              <span
                class="book-card-badge"
                style={`background: ${accent};`}
              >
                {book.age}
              </span>
              <p
                class="book-card-role-label challenge-simple-role text-base sm:text-lg"
                style={`color: ${accent};`}
              >
                {book.role}
              </p>
            </div>
            {book.challengeHeadline && (
              <p class="challenge-simple-headline">{book.challengeHeadline}</p>
            )}
            <p class="challenge-simple-text">{book.challenge}</p>

            <div class="challenge-simple-deliverable">
              <h2 class="challenge-simple-deliverable-title">Entregable</h2>
              <p class="challenge-simple-deliverable-text">{book.deliverable}</p>
            </div>
          </section>
        ) : (
          <>
            <section class="book-detail-section mt-6">
              <h2 class="book-detail-heading">Tu reto con este libro</h2>
              {book.challengeIntro && (
                <p class="mt-3 text-sm text-gray-600 leading-relaxed">
                  {book.challengeIntro}
                </p>
              )}
              <p class="mt-3 text-ink-800 leading-relaxed">
                {book.challenge}
              </p>
              {book.formats.length > 0 && (
                <p class="mt-4 text-sm text-ink-800">
                  <span class="font-semibold">Puedes enviarlo como:</span>{" "}
                  {book.formats.join(" · ")}
                </p>
              )}
            </section>

            <section class="book-detail-section mt-6 pt-6 border-t border-gray-200">
              <h2 class="book-detail-heading">Antes de enviar</h2>
              <ul class="mt-4 space-y-2">
                {book.requirements.map((req) => (
                  <li class="challenge-list-item">{req}</li>
                ))}
              </ul>
            </section>
          </>
        )}

        {book.basesPdf && (
          <div class="book-detail-actions mt-6">
            <a
              href={book.basesPdf}
              download={`Bases ${book.title.split(",")[0]}.pdf`}
              class="challenge-instructions-btn"
              target="_blank"
              rel="noreferrer"
            >
              Ver indicaciones completas
            </a>
          </div>
        )}

        <div class="book-detail-cta">
          <p class="book-detail-cta-text">
            {book.participateNote}
          </p>
          <div class="book-detail-actions">
            <a href={participarUrl} class="btn-primary book-detail-btn">
              Participar ahora
            </a>
          </div>
        </div>
      </div>
      </div>
    </div>

    <img
      src="/estrellas izquierda.png"
      alt=""
      class="book-detail-stars-left"
      width={340}
      height={340}
      loading="eager"
      decoding="async"
      aria-hidden="true"
    />
    <img
      src="/luna.png"
      alt=""
      class="book-detail-moon"
      width={340}
      height={340}
      loading="eager"
      decoding="async"
      aria-hidden="true"
    />
  </div>
</BaseLayout>

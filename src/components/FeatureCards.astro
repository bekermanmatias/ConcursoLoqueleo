---
const cards = [
  {
    id: "premios",
    title: "Premios increíbles",
    desc: "Libros, kits creativos, talleres con autores y reconocimientos nacionales para tu colegio.",
    href: "#premios",
    emoji: "🏆",
    accent: "#f5e6a8",
  },
  {
    id: "recursos",
    title: "Recursos para docentes",
    desc: "Guías, fichas y materiales para acompañar la lectura y los retos en el aula.",
    href: "#como-participar",
    emoji: "🎒",
    accent: "#b8e8e0",
  },
];
---

<section class="grid sm:grid-cols-2 gap-5 sm:gap-6 pb-16 sm:pb-20">
  {cards.map((card) => (
    <a
      id={card.id}
      href={card.href}
      class="glass-card rounded-3xl p-6 sm:p-8 flex flex-col sm:flex-row items-center gap-6 transition hover:shadow-lg hover:-translate-y-0.5"
    >
      <div
        class="shrink-0 w-28 h-28 sm:w-32 sm:h-32 rounded-2xl grid place-items-center text-5xl sm:text-6xl"
        style={`background: ${card.accent};`}
      >
        {card.emoji}
      </div>
      <div class="text-center sm:text-left">
        <h3 class="text-lg sm:text-xl font-extrabold text-[color:var(--color-ink-900)] uppercase tracking-tight">
          {card.title}
        </h3>
        <p class="mt-2 text-sm text-[color:var(--color-ink-700)] leading-relaxed">
          {card.desc}
        </p>
      </div>
    </a>
  ))}
</section>

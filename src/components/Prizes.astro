---
import WaveDivider from "./WaveDivider.astro";

const prizes = [
  {
    icon: "🏆",
    title: "1.er puesto",
    desc:  "Kit Loqueleo + taller con autor + reconocimiento nacional.",
    tint:  "var(--color-sun-300)",
  },
  {
    icon: "🎒",
    title: "2.do puesto",
    desc:  "Biblioteca personal Loqueleo + materiales creativos.",
    tint:  "var(--color-aqua-300)",
  },
  {
    icon: "🎁",
    title: "3.er puesto",
    desc:  "Pack de libros y diploma especial del concurso.",
    tint:  "var(--color-blush-300)",
  },
];
---

<section id="premios" class="relative">
  <!-- Onda superior conectando con la sección previa -->
  <WaveDivider color="var(--color-aqua-100)" height={110} flip={true} />

  <div class="bg-[color:var(--color-aqua-100)]/70 backdrop-blur-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-24">
      <header class="text-center mb-12">
        <p class="inline-block px-3 py-1 rounded-full bg-white/80 text-xs font-semibold tracking-[0.18em] uppercase text-[color:var(--color-ink-600)] border border-white/70">
          Premios
        </p>
        <h2 class="title-display mt-4 text-3xl sm:text-5xl font-extrabold">
          Cumple el reto · <span class="text-[color:var(--color-aqua-600)]">¡y gana!</span>
        </h2>
      </header>

      <div class="grid gap-7 sm:grid-cols-3">
        {prizes.map((p, idx) => (
          <article class="card-paper p-7 text-center relative">
            <div
              class="mx-auto w-20 h-20 grid place-items-center text-3xl shadow-md"
              class:list={[["blob-1","blob-2","blob-3"][idx % 3]]}
              style={`background: ${p.tint};`}
            >
              {p.icon}
            </div>
            <h3 class="mt-5 text-xl font-extrabold text-[color:var(--color-ink-900)]">{p.title}</h3>
            <p class="mt-2 text-sm text-[color:var(--color-ink-700)]">{p.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </div>

  <!-- Onda inferior -->
  <WaveDivider color="var(--color-aqua-100)" height={110} />
</section>

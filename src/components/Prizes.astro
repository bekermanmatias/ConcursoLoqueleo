---
import {
  prizeCategories,
  prizeSummaryIcons,
  prizeWinSummaries,
  prizesOverview,
  type PrizeAudience,
} from "../data/prizes";

const summaryOrder: PrizeAudience[] = ["estudiantes", "docentes", "colegios"];
---

<section class="prizes-section" data-nav-section="premios" aria-labelledby="premios-title">
  <header id="premios" class="prizes-header">
    <h2 id="premios-title" class="section-title">Premios</h2>
    <p class="prizes-subtitle">{prizesOverview.intro}</p>
  </header>

  <div class="prizes-how-grid" aria-label="¿Quién puede ganar y cómo?">
    {summaryOrder.map((audience) => (
      <article class={`prizes-how-card prizes-how-card--${audience}`}>
        <img
          class="prizes-how-card-icon"
          src={prizeSummaryIcons[audience]}
          alt=""
          width={112}
          height={112}
          loading="lazy"
          decoding="async"
        />
        <div class="prizes-how-card-copy">
          <h3 class="prizes-how-card-title">{prizeWinSummaries[audience].title}</h3>
          <p class="prizes-how-card-text">{prizeWinSummaries[audience].text}</p>
        </div>
      </article>
    ))}
  </div>

  <div class="prizes-columns">
    {prizeCategories.map((category) => (
      <div class={`prizes-column prizes-column--${category.id}`}>
        <header class={`prizes-column-intro prizes-column-intro--${category.id}`}>
          <h3 class="prizes-column-title">{category.label}</h3>
          <p class="prizes-column-grades">{category.grades}</p>
        </header>

        <div class="prizes-group-cards">
          {category.blocks.map((block) => (
            <article class={`prizes-item prizes-item--${block.audience}`}>
              <h5 class="prizes-item-title">{block.title}</h5>

              <div class="prizes-item-photo prizes-photo-slot" data-photo-id={block.id}>
                {block.photo ? (
                  <img
                    src={block.photo}
                    alt={`${block.title} — ${category.label}`}
                    class="prizes-photo-img"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <span class="prizes-photo-placeholder" aria-hidden="true" />
                )}
              </div>

              <div class="prizes-item-body">
                <div class="prizes-item-how">
                  <p class="prizes-item-label">¿Cómo se gana?</p>
                  <p class="prizes-item-text">{block.howToWin}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    ))}
  </div>

  <p class="prizes-footer-note">{prizesOverview.juryNote}</p>
</section>

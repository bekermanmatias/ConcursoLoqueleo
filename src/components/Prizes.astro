---
import {
  prizeCategories,
  prizeWinSummaries,
  prizesOverview,
  type PrizeAudience,
  type PrizeBlock,
  type PrizeCategory,
} from "../data/prizes";

const summaryOrder: PrizeAudience[] = ["estudiantes", "docentes", "colegios"];

const primaria = prizeCategories.find((c) => c.id === "primaria")!;
const secundaria = prizeCategories.find((c) => c.id === "secundaria")!;

function blockFor(category: PrizeCategory, audience: PrizeAudience): PrizeBlock {
  return category.blocks.find((b) => b.audience === audience)!;
}
---

<section class="prizes-section" data-nav-section="premios" aria-labelledby="premios-title">
  <header id="premios" class="prizes-header">
    <h2 id="premios-title" class="section-title">Premios</h2>
    <p class="prizes-subtitle">{prizesOverview.intro}</p>
  </header>

  <div class="prizes-how-grid" aria-label="¿Quién puede ganar y cómo?">
    {summaryOrder.map((audience) => (
      <article class={`prizes-how-card prizes-how-card--${audience}`}>
        <h3 class="prizes-how-card-title">{prizeWinSummaries[audience].title}</h3>
        <p class="prizes-how-card-text">{prizeWinSummaries[audience].text}</p>
      </article>
    ))}
  </div>

  <div class="prizes-matrix">
    <div class="prizes-matrix-row prizes-matrix-row--headers">
      <header class={`prizes-column-intro prizes-column-intro--${primaria.id}`}>
        <h3 class="prizes-column-title">{primaria.label}</h3>
        <p class="prizes-column-grades">{primaria.grades}</p>
      </header>
      <header class={`prizes-column-intro prizes-column-intro--${secundaria.id}`}>
        <h3 class="prizes-column-title">{secundaria.label}</h3>
        <p class="prizes-column-grades">{secundaria.grades}</p>
      </header>
    </div>

    {summaryOrder.map((audience) => (
      <div class="prizes-matrix-row">
        {[primaria, secundaria].map((category) => {
          const block = blockFor(category, audience);
          return (
            <article class={`prizes-block prizes-block--${block.audience}`}>
              <div class="prizes-block-photo prizes-photo-slot" data-photo-id={block.id}>
                {block.photo ? (
                  <img
                    src={block.photo}
                    alt={`Premio para ${block.title.toLowerCase()} — ${category.label}`}
                    class="prizes-photo-img"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <span class="prizes-photo-placeholder" aria-hidden="true" />
                )}
              </div>

              <div class="prizes-block-copy">
                <h4 class="prizes-block-title">{block.title}</h4>
                <p class="prizes-block-place">1.er puesto · {category.grades}</p>

                <div class="prizes-block-how">
                  <p class="prizes-block-how-label">¿Cómo se gana?</p>
                  <p class="prizes-block-how-text">{block.howToWin}</p>
                </div>

                <p class="prizes-block-prizes-label">Qué se entrega</p>
                <ul class="prizes-block-list">
                  {block.items.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            </article>
          );
        })}
      </div>
    ))}
  </div>

  <p class="prizes-footer-note">{prizesOverview.juryNote}</p>
</section>

---
import type { Book } from "../data/books";
import { ageCardColors, ageUiStyles } from "../data/books";

interface Props {
  book: Book;
}

const { book } = Astro.props;
const cardBg = ageCardColors[book.age];
const uiStyle = ageUiStyles[book.age];
---

<article data-age={book.age} class="group">
  <div
    class="rounded-[22px] border-2 bg-white p-3 sm:p-3.5 shadow-sm transition hover:shadow-md"
    style={`border-color: ${uiStyle.badgeBg};`}
  >
    <a href={`#participar-${book.id}`} class="block overflow-hidden rounded-[14px]">
      <!-- Tapa -->
      <div class="aspect-[3/4] overflow-hidden bg-white">
        <img
          src={book.cover}
          alt={book.title}
          loading="lazy"
          class="w-full h-full object-cover"
        />
      </div>
    </a>

    <!-- Bloque inferior de color -->
    <div class="mt-2 px-3 py-3 text-center rounded-[12px]" style={`background: ${cardBg};`}>
      <h3 class="text-sm font-extrabold text-[color:var(--color-ink-900)] leading-snug line-clamp-2">{book.title}</h3>
      <p class="mt-1 text-xs text-[color:var(--color-ink-700)] line-clamp-1">{book.author}</p>
    </div>

    <div class="mt-3 text-center">
      <div class="flex items-center justify-center gap-2">
      <span class="w-8 h-8 rounded-full grid place-items-center text-white text-sm font-extrabold" style={`background:${uiStyle.badgeBg};`}>
        {book.age}
      </span>
      <p class="text-[1.06rem] leading-tight font-medium" style={`color:${uiStyle.roleText};`}>
        {book.role}
      </p>
      </div>

      <a
        href={`#participar-${book.id}`}
        class:list={[
          "mt-3 inline-flex w-full justify-center items-center rounded-xl py-2.5 text-base font-bold transition",
          uiStyle.button,
        ]}
      >
        Participar
      </a>
    </div>
  </div>
</article>

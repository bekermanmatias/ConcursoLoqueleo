---
import Countdown from "./Countdown.tsx";
import HowToParticipate from "./HowToParticipate.astro";
---

<section id="inicio" class="pt-10 sm:pt-14 pb-12 sm:pb-16">
  <div class="grid lg:grid-cols-[1fr_auto] gap-10 lg:gap-12 items-start">
    <!-- Texto hero (izquierda) -->
    <div class="max-w-xl">
      <p class="text-sm font-bold uppercase tracking-wide text-[color:var(--color-brand-red)] mb-2">
        Concurso
      </p>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-[color:var(--color-ink-900)] leading-[1.08] tracking-tight">
        Soy Loqueleo 2026
      </h1>

      <p class="mt-4 text-xl sm:text-2xl font-bold text-[color:var(--color-ink-900)]">
        Lee, crea y gana junto a tu colegio
      </p>

      <p class="mt-4 text-sm sm:text-base text-[color:var(--color-ink-700)] leading-relaxed max-w-md">
        Participan todos los estudiantes, docentes y colegios usuarios de Loqueleo.
        Elige tu libro, cumple el reto de tu grado y compite por increíbles premios.
      </p>

      <a href="#retos" class="btn-primary mt-8 text-base">
        Participa ahora
      </a>
    </div>

    <!-- Astronauta y alien a la derecha -->
    <div class="lg:pt-2 lg:translate-x-8">
      <img
        src="/ASTRONAUTA Y ALIEN.png"
        alt="Astronauta y alien"
        class="astronaut-float w-full max-w-[620px] xl:max-w-[760px] h-auto object-contain mx-auto mt-8 lg:mt-20 opacity-75"
        decoding="async"
      />
    </div>
  </div>

  <div class="relative z-20 left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen -mt-72 sm:-mt-80 lg:-mt-96 bg-white pt-5 sm:pt-7 pb-48 sm:pb-56 lg:pb-64">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Countdown client:load />
      <div class="countdown-divider" role="separator" aria-hidden="true"></div>
      <HowToParticipate />
    </div>
  </div>
</section>

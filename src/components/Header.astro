---
const nav = [
  { label: "Inicio",            href: "/",                   active: true },
  { label: "¿Cómo participar?", href: "#como-participar",    active: false },
  { label: "Regístrate",        href: "#registrate",         active: false },
  { label: "Premios",           href: "#premios",            active: false },
  { label: "Ganadores",         href: "#ganadores",          active: false },
];
---

<header class="w-full bg-white sticky top-0 z-50 shadow-[0_4px_24px_-4px_rgba(0,0,0,0.12)]">
  <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-10 h-[5.5rem] sm:h-[6.25rem] flex items-center justify-between gap-6">

    <a href="/" class="shrink-0">
      <img
        src="/loqueleo.png"
        alt="Loqueleo"
        class="h-12 sm:h-14 lg:h-16 w-auto"
        width="180"
        height="64"
      />
    </a>

    <nav class="hidden md:flex items-center justify-end gap-8 lg:gap-10 ml-auto">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "group text-base lg:text-lg font-semibold transition flex flex-col items-center leading-none",
            item.active
              ? "text-[color:var(--color-brand-red)]"
              : "text-[color:var(--color-ink-800)] hover:text-[color:var(--color-brand-red)]",
          ]}
        >
          {item.label}
          <span
            class:list={[
              "mt-1 h-3 w-9 transition-opacity duration-150",
              item.active ? "opacity-100" : "opacity-0 group-hover:opacity-100",
            ]}
            style="
              background-color: var(--color-brand-red);
              -webkit-mask-image: url('/libro.svg');
              -webkit-mask-repeat: no-repeat;
              -webkit-mask-position: center;
              -webkit-mask-size: contain;
              mask-image: url('/libro.svg');
              mask-repeat: no-repeat;
              mask-position: center;
              mask-size: contain;
            "
            aria-hidden="true"
          />
        </a>
      ))}
    </nav>

  </div>

  <!-- Nav móvil -->
  <nav class="md:hidden flex overflow-x-auto gap-5 px-5 pb-4 border-t border-gray-100">
    {nav.map((item) => (
      <a
        href={item.href}
        class:list={[
          "group text-sm font-semibold whitespace-nowrap shrink-0 py-1 flex flex-col items-center leading-none",
          item.active
            ? "text-[color:var(--color-brand-red)]"
            : "text-[color:var(--color-ink-800)]",
        ]}
      >
        {item.label}
        <span
          class:list={[
            "mt-1 h-2.5 w-8 transition-opacity duration-150",
            item.active ? "opacity-100" : "opacity-0 group-hover:opacity-100",
          ]}
          style="
            background-color: var(--color-brand-red);
            -webkit-mask-image: url('/libro.svg');
            -webkit-mask-repeat: no-repeat;
            -webkit-mask-position: center;
            -webkit-mask-size: contain;
            mask-image: url('/libro.svg');
            mask-repeat: no-repeat;
            mask-position: center;
            mask-size: contain;
          "
          aria-hidden="true"
        />
      </a>
    ))}
  </nav>
</header>

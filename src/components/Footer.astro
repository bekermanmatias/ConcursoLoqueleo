---
const concurso = [
  { label: "Inicio", href: "/" },
  { label: "¿Cómo participar?", href: "#como-participar" },
  { label: "Regístrate", href: "#registrate" },
  { label: "Premios", href: "#premios" },
  { label: "Ganadores", href: "#ganadores" },
];

const recursos = [
  { label: "Explora los libros", href: "#libros" },
  { label: "Reimprimir certificado", href: "#certificado" },
  { label: "Loqueleo.com", href: "https://www.loqueleo.com", external: true },
];
---

<footer class="relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen bg-[color:var(--color-ink-900)] text-white mt-8 sm:mt-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-14">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Marca -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="inline-block">
          <img
            src="/loqueleo.png"
            alt="Loqueleo"
            class="h-10 w-auto brightness-0 invert"
            width="140"
            height="40"
          />
        </a>
        <p class="mt-4 text-sm text-white/70 leading-relaxed max-w-xs">
          Concurso Soy Loqueleo 2026. Lee, crea y gana junto a tu colegio con los retos literarios de tu edad.
        </p>
      </div>

      <!-- Concurso -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest text-white/50 mb-4">
          Concurso
        </h3>
        <ul class="space-y-2.5">
          {concurso.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-white/85 hover:text-white transition"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Recursos -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest text-white/50 mb-4">
          Recursos
        </h3>
        <ul class="space-y-2.5">
          {recursos.map((link) => (
            <li>
              <a
                href={link.href}
                target={link.external ? "_blank" : undefined}
                rel={link.external ? "noopener noreferrer" : undefined}
                class="text-sm text-white/85 hover:text-white transition inline-flex items-center gap-1"
              >
                {link.label}
                {link.external && (
                  <span class="text-white/50" aria-hidden="true">↗</span>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest text-white/50 mb-4">
          Contacto
        </h3>
        <ul class="space-y-2.5 text-sm text-white/85">
          <li>
            <a href="mailto:concurso@loqueleo.com" class="hover:text-white transition">
              concurso@loqueleo.com
            </a>
          </li>
          <li>Lima, Perú</li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Barra inferior -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-white/60">
      <p>© {new Date().getFullYear()} Loqueleo. Todos los derechos reservados.</p>
      <p>Concurso Soy Loqueleo 2026</p>
    </div>
  </div>
</footer>

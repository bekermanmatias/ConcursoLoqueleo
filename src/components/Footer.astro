---
import WaveDivider from "./WaveDivider.astro";
---

<footer class="relative mt-10 text-[color:var(--color-ink-800)]">
  <!-- Onda superior conectando con el bloque previo -->
  <WaveDivider color="var(--color-ink-700)" height={120} flip={true} className="-mb-px" />

  <div class="bg-[color:var(--color-ink-700)] text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 grid gap-10 sm:grid-cols-3">
      <div>
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 blob-1 grid place-items-center font-extrabold bg-[color:var(--color-aqua-400)] text-[color:var(--color-ink-900)]">
            Lq
          </div>
          <p class="font-extrabold text-lg">Soy loqueleo <span class="text-[color:var(--color-aqua-300)]">2026</span></p>
        </div>
        <p class="mt-3 text-sm text-white/80 max-w-xs">
          Un concurso de lectura, creatividad e ilustración para estudiantes, docentes y colegios usuarios de Loqueleo.
        </p>
      </div>

      <div>
        <h4 class="font-bold mb-3 text-white">Concurso</h4>
        <ul class="space-y-2 text-sm text-white/80">
          <li><a href="#como-participar" class="hover:text-white">¿Cómo participar?</a></li>
          <li><a href="#libros"           class="hover:text-white">Obras y retos</a></li>
          <li><a href="#premios"          class="hover:text-white">Premios</a></li>
          <li><a href="#ganadores"        class="hover:text-white">Ganadores</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-bold mb-3 text-white">Contacto</h4>
        <ul class="space-y-2 text-sm text-white/80">
          <li>Lima, Perú</li>
          <li>concurso@loqueleo.com</li>
          <li>+51 (01) 000-0000</li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-white/70">
        <p>© {new Date().getFullYear()} Loqueleo. Todos los derechos reservados.</p>
        <p>Hecho con cariño · estilo acuarela digital</p>
      </div>
    </div>
  </div>
</footer>

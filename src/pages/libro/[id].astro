---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getBookById, getAllBookIds } from "../../lib/books";
import { ageUiStyles } from "../../data/books";

export function getStaticPaths() {
  return getAllBookIds().map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
const book = getBookById(id!);

if (!book) {
  return Astro.redirect("/");
}

const { accent } = ageUiStyles[book.age];
const participarUrl = `/libro/${book.id}/participar`;
---

<BaseLayout
  title={`${book.title} — Soy Loqueleo 2026`}
  description={book.challenge}
>
  <div class="py-6 sm:py-10">
    <div class="grid lg:grid-cols-[minmax(200px,280px)_1fr] gap-8 lg:gap-12 items-start">
      <div class="mx-auto lg:mx-0 w-full max-w-[280px]">
        <div
          class="rounded-2xl border-2 overflow-hidden shadow-lg bg-white"
          style={`border-color: ${accent};`}
        >
          <img
            src={book.cover}
            alt={`Tapa de ${book.title}`}
            width={280}
            height={374}
            class="w-full h-auto block"
          />
        </div>
      </div>

      <div class="min-w-0">
        <div class="book-card-role justify-start">
          <span
            class="book-card-badge"
            style={`background: ${accent};`}
          >
            {book.age}
          </span>
          <p
            class="book-card-role-label text-base sm:text-lg"
            style={`color: ${accent};`}
          >
            {book.role}
          </p>
        </div>
        <h1 class="mt-1 text-2xl sm:text-3xl lg:text-4xl font-extrabold text-ink-900 leading-tight">
          {book.title}
        </h1>
        <p class="mt-2 text-gray-500">{book.author}</p>

        <section class="flow-panel mt-8">
          <h2 class="text-lg font-bold text-ink-900">Tu reto con este libro</h2>
          {book.challengeIntro && (
            <p class="mt-3 text-sm text-gray-600 leading-relaxed">
              {book.challengeIntro}
            </p>
          )}
          <p class="mt-3 text-ink-800 leading-relaxed">
            {book.challenge}
          </p>
          {book.formats.length > 0 && (
            <p class="mt-4 text-xs font-semibold uppercase tracking-wide text-gray-400">
              Puedes enviarlo como
            </p>
          )}
          <div class="mt-2 flex flex-wrap gap-2">
            {book.formats.map((f) => (
              <span class="flow-tag">{f}</span>
            ))}
          </div>
        </section>

        <section class="flow-panel mt-5">
          <h2 class="text-lg font-bold text-ink-900">Antes de enviar</h2>
          <p class="mt-2 text-sm text-gray-600 leading-relaxed">
            Revisa esto con tu docente o en casa para no tener que repetir el trabajo.
          </p>
          <ul class="mt-4 space-y-2.5">
            {book.requirements.map((req) => (
              <li class="flow-check-item">{req}</li>
            ))}
          </ul>
        </section>

        <section class="flow-panel mt-5">
          <h2 class="text-lg font-bold text-ink-900">Inscripción</h2>
          <p class="mt-3 text-sm text-ink-800 leading-relaxed">
            {book.participateNote}
          </p>
        </section>

        <a
          href={participarUrl}
          class="btn-primary mt-8 w-full sm:w-auto inline-flex justify-center text-base px-10 py-4"
        >
          Participar ahora
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

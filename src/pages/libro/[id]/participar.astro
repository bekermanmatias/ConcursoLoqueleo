---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import RegistrationWizard from "../../../components/flow/RegistrationWizard.tsx";
import { getBookById, getAllBookIds } from "../../../lib/books";
import { ageUiStyles } from "../../../data/books";

export function getStaticPaths() {
  return getAllBookIds().map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
const book = getBookById(id!);

if (!book) {
  return Astro.redirect("/");
}

const { accent } = ageUiStyles[book.age];
---

<BaseLayout
  title={`Participar — ${book.title}`}
  description="Registro y subida de tu trabajo para Soy Loqueleo 2026."
>
  <div class="py-6 sm:py-10">
    <nav class="mb-8 flex flex-wrap items-center justify-between gap-3">
      <a
        href={`/libro/${book.id}`}
        class="text-sm font-semibold text-gray-500 hover:text-[color:var(--color-brand-red)] transition"
      >
        ← Volver al reto
      </a>
      <span class="text-sm font-semibold text-gray-400">{book.title}</span>
    </nav>

    <header class="text-center max-w-lg mx-auto mb-8">
      <h1 class="text-2xl sm:text-3xl font-extrabold text-ink-900">
        Registro y subida
      </h1>
      <p class="mt-2 text-gray-500 text-sm">
        Rápido, guiado y seguro. Completa los pasos para enviar tu participación.
      </p>
    </header>

    <RegistrationWizard
      client:load
      bookId={book.id}
      bookTitle={book.title}
      accent={accent}
    />
  </div>
</BaseLayout>

---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import RegistrationWizard from "../../../components/flow/RegistrationWizard.tsx";
import { getBookById, getAllBookIds } from "../../../lib/books";
import { ageUiStyles } from "../../../data/books";

export function getStaticPaths() {
  return getAllBookIds().map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
const book = getBookById(id!);

if (!book) {
  return Astro.redirect("/");
}

const { accent } = ageUiStyles[book.age];
---

<BaseLayout
  title={`Participar — ${book.title}`}
  description="Registro y subida de tu trabajo para Soy Loqueleo 2026."
>
  <div class="book-detail-page py-4 sm:py-6 pb-12 sm:pb-16 lg:pb-20">
    <div class="book-detail-inner relative z-10">
      <div class="participar-form">
        <RegistrationWizard
          client:load
          bookId={book.id}
          bookTitle={book.title}
          accent={accent}
        />
      </div>
    </div>

    <img
      src="/estrellas izquierda.png"
      alt=""
      class="book-detail-stars-left"
      width={340}
      height={340}
      loading="eager"
      decoding="async"
      aria-hidden="true"
    />
    <img
      src="/luna.png"
      alt=""
      class="book-detail-moon"
      width={340}
      height={340}
      loading="eager"
      decoding="async"
      aria-hidden="true"
    />
  </div>
</BaseLayout>

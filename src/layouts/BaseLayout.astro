---
import "../styles/global.css";
import Header from "../components/Header.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Concurso Soy Loqueleo 2026",
  description = "Lee, crea y gana junto a tu colegio. Participan estudiantes, docentes y colegios usuarios de Loqueleo.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/loqueleo_minimal.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="antialiased overflow-x-hidden">
    <Header />

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <main>
        <slot />
      </main>

      <footer class="py-10 text-center text-sm text-[color:var(--color-ink-700)]">
        <p>© {new Date().getFullYear()} Loqueleo · Concurso Soy Loqueleo 2026</p>
      </footer>
    </div>
  </body>
</html>

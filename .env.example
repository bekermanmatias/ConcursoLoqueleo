# =============================================================================
# Desarrollo local (Docker Compose)
# =============================================================================
POSTGRES_USER=loqueleo
POSTGRES_PASSWORD=loqueleo
POSTGRES_DB=loqueleo
POSTGRES_PORT=5432

FRONTEND_PORT=80
BACKEND_PORT=3000

NODE_ENV=development
CORS_ORIGIN=http://localhost
# También funciona en http://localhost:8080 (mismo contenedor, puerto alternativo)

DATABASE_URL=postgres://loqueleo:loqueleo@localhost:5432/loqueleo
APP_DOMAIN=concursope.loqueleo.com

# local = disco del servidor (simula S3). s3 = carga directa (AWS o MinIO).
STORAGE_MODE=local
STORAGE_LOCAL_DIR=./uploads
UPLOAD_TOKEN_SECRET=dev-upload-secret-change-me
JWT_SECRET=dev-jwt-secret-change-me
MAX_PDF_BYTES=10485760
MAX_VIDEO_BYTES=262144000
CODIGO_CONCURSO=LQL2026

# Vacío = rutas /api relativas (proxy en dev y nginx en prod)
PUBLIC_API_URL=

# URL del API al generar el sitio estático (build Astro). En Docker: http://backend:3000
BUILD_API_URL=http://localhost:3000

# Puerto que usa el navegador en Docker dev (HMR). Debe coincidir con cómo abres el sitio.
HMR_CLIENT_PORT=8080

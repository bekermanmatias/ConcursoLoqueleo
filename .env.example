# =============================================================================
# Desarrollo local (Docker Compose)
# =============================================================================
POSTGRES_USER=loqueleo
POSTGRES_PASSWORD=loqueleo
POSTGRES_DB=loqueleo
POSTGRES_PORT=5432

FRONTEND_PORT=8080
BACKEND_PORT=3000

NODE_ENV=development
CORS_ORIGIN=http://localhost:8080
# Astro dev: CORS_ORIGIN=http://localhost:4321

DATABASE_URL=postgres://loqueleo:loqueleo@localhost:5432/loqueleo
APP_DOMAIN=concursope.loqueleo.com

# local = sin S3 (solo metadatos). s3 = carga directa (AWS o MinIO).
STORAGE_MODE=local

PUBLIC_API_URL=

# =============================================================================
# Producción AWS (ECS + RDS + S3) — copiar a Bamboo / Secrets Manager
# =============================================================================
# NODE_ENV=production
# DATABASE_URL=postgres://USER:PASS@rds-endpoint:5432/loqueleo
# CORS_ORIGIN=https://concursope.loqueleo.com
# STORAGE_MODE=s3
# AWS_REGION=us-east-1
# S3_UPLOAD_BUCKET=loqueleo-entregables-prod
# S3_UPLOAD_PREFIX=entregables
# S3_PUBLIC_URL_BASE=https://entregables.concursope.loqueleo.com
# MAX_PDF_BYTES=10485760
# MAX_VIDEO_BYTES=262144000
# Credenciales AWS: IAM Task Role en ECS (preferido) o AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY
